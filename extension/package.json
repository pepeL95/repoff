{
  "name": "copilot-bridge-extension",
  "displayName": "Copilot Bridge",
  "description": "Local-only VS Code extension that exposes a localhost bridge backed by the public VS Code Language Model API.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.99.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:copilotBridge.showStatus",
    "onCommand:copilotBridge.restartBridge",
    "onCommand:copilotBridge.copyEndpoint"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotBridge.showStatus",
        "title": "LM Bridge: Show Status"
      },
      {
        "command": "copilotBridge.restartBridge",
        "title": "LM Bridge: Restart Bridge"
      },
      {
        "command": "copilotBridge.copyEndpoint",
        "title": "LM Bridge: Copy Endpoint"
      }
    ],
    "configuration": {
      "title": "Copilot Bridge",
      "properties": {
        "copilotBridge.port": {
          "type": "number",
          "default": 8765,
          "description": "Localhost WebSocket port for the bridge server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf dist *.vsix",
    "package": "npm run build && ../scripts/package-extension.sh"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.24.0",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.5.12",
    "@types/vscode": "^1.99.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "ws": "^8.18.1"
  }
}
