{
  "name": "copilot-bridge-extension",
  "displayName": "Copilot Bridge",
  "description": "Minimal VS Code extension that smoke-tests the public Language Model API.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.99.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:copilotBridge.showStatus",
    "onCommand:copilotBridge.startServer",
    "onCommand:copilotBridge.stopServer",
    "onCommand:copilotBridge.listModels",
    "onCommand:copilotBridge.smokeTest"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotBridge.showStatus",
        "title": "LM Bridge: Show Status"
      },
      {
        "command": "copilotBridge.startServer",
        "title": "LM Bridge: Start Server"
      },
      {
        "command": "copilotBridge.stopServer",
        "title": "LM Bridge: Stop Server"
      },
      {
        "command": "copilotBridge.listModels",
        "title": "LM Bridge: List Models"
      },
      {
        "command": "copilotBridge.smokeTest",
        "title": "LM Bridge: Run Prompt"
      }
    ]
    ,
    "configuration": {
      "title": "Copilot Bridge",
      "properties": {
        "copilotBridge.port": {
          "type": "number",
          "default": 8765,
          "description": "Localhost WebSocket port for the bridge server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf dist *.vsix",
    "package": "npm run build && ../scripts/package-extension.sh"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.24.0",
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.99.0",
    "typescript": "^5.8.3"
  }
}
