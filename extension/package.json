{
  "name": "copilot-bridge-extension",
  "displayName": "Copilot Bridge",
  "description": "Minimal VS Code extension that smoke-tests the public Language Model API.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.99.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:copilotBridge.showStatus",
    "onCommand:copilotBridge.startServer",
    "onCommand:copilotBridge.stopServer",
    "onCommand:copilotBridge.listModels",
    "onCommand:copilotBridge.smokeTest"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotBridge.showStatus",
        "title": "LM Bridge: Show Status"
      },
      {
        "command": "copilotBridge.startServer",
        "title": "LM Bridge: Start Server"
      },
      {
        "command": "copilotBridge.stopServer",
        "title": "LM Bridge: Stop Server"
      },
      {
        "command": "copilotBridge.listModels",
        "title": "LM Bridge: List Models"
      },
      {
        "command": "copilotBridge.smokeTest",
        "title": "LM Bridge: Run Prompt"
      }
    ],
    "languageModelTools": [
      {
        "name": "delegate_task",
        "displayName": "Delegate Task",
        "toolReferenceName": "delegateTask",
        "modelDescription": "Delegate a coding task to a worker agent and wait for its final response. Use this when work should be handed off to a separate SWE worker identified by recipient. The tool returns the worker's final response text.",
        "userDescription": "Delegate a task to a worker agent and wait for the response.",
        "canBeReferencedInPrompt": true,
        "icon": "$(send)",
        "tags": [
          "agent",
          "delegation",
          "messaging"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "recipient": {
              "type": "string",
              "description": "The worker recipient id that should receive the task, for example swe-agent-1."
            },
            "content": {
              "type": "string",
              "description": "The task instructions that should be sent to the worker."
            },
            "timeout_seconds": {
              "type": "number",
              "description": "How long to wait for the worker response before failing."
            }
          },
          "required": [
            "recipient",
            "content"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Copilot Bridge",
      "properties": {
        "copilotBridge.port": {
          "type": "number",
          "default": 8765,
          "description": "Localhost port for the VS Code LM adapter server."
        },
        "copilotBridge.backendPort": {
          "type": "number",
          "default": 8766,
          "description": "Localhost port for the Python backend server."
        }
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p .",
    "clean": "rm -rf dist *.vsix",
    "package": "npm run build && ../scripts/package-extension.sh"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.24.0",
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.99.0",
    "typescript": "^5.8.3"
  }
}
